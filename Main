var greendownDOY = greendown_timing_file.computeGreendownDate(
  hlsEVI,
  route_buffer,
  2025
);

Map.addLayer(
  greendownDOY,
  {
    min: 220,
    max: 340,
    palette: [
      'darkgreen',
      'green',
      'yellow',
      'orange',
      'red'
    ]
  },
  'Greendown DOY'
);
