exports.computeGreendownDate = function(hlsEVI, year) {
  // July mean EVI
  var julyMean = hlsEVI
    .filterDate(year + '-07-01', year + '-07-31')
    .mean();

  // December mean EVI
  var decMean = hlsEVI
    .filterDate(year + '-12-01', year + '-12-31')
    .mean();

  // 25% decline threshold
  var threshold = julyMean.subtract(
    julyMean.subtract(decMean).multiply(0.25)
  );

  // Only search after July
  var lateSeason = hlsEVI.filterDate(
    year + '-07-01',
    year + '-12-31'
  );

  // Add DOY band
  var withDOY = lateSeason.map(function(img) {

    var doy = ee.Date(img.get('system:time_start'))
      .getRelative('day', 'year')
      .add(1);

    return img.addBands(
      ee.Image.constant(doy).rename('DOY')
    );
  });

  // Keep dates where EVI <= threshold
  var belowThreshold = withDOY.map(function(img) {

    var crossed = img.select('EVI').lte(threshold);

    return img.select('DOY')
      .updateMask(crossed)
      .copyProperties(img, ['system:time_start']);
  });

  // First date crossing threshold
  var greendownDOY = belowThreshold.min();

  return greendownDOY.rename('Greendown_DOY');
}